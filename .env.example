# AI 智能择时助手 - 环境变量配置示例
# 复制此文件为 .env 并填入实际的 API 密钥

# ==================== AI 服务配置 ====================
# 阿里云千问 API Key（推荐，有免费额度）
# 获取地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# ==================== 数据源配置 ====================
# Tushare Token（可选，用于获取更专业的数据）
# 获取地址：https://tushare.pro/register
# 注意：本项目主要使用免费的 AkShare，Tushare 为可选数据源
TUSHARE_TOKEN=your_tushare_token_here

# ==================== 应用配置 ====================
# 是否启用 AI 分析（true/false）
ENABLE_AI=true

# 是否启用缓存（true/false）
ENABLE_CACHE=true
